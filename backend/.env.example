# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── App URL (used for OxaPay webhook & return URL) ────────────────────────────
APP_URL=https://gampr-apk-production.up.railway.app

# ── OxaPay — automated USDT payment gateway ──────────────────────────────────
# Obtain from: https://oxapay.com → Settings → API Keys → Merchant Key
# These are fallback env vars; the admin panel (Settings → OxaPay) takes priority.
OXAPAY_MERCHANT_KEY=
OXAPAY_CURRENCY=USD
OXAPAY_LIFETIME=30

# ── Cloudinary (optional — for payment proof image uploads) ──────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── BscScan (for manual USDT BEP20 TXID verification) ────────────────────────
BSCSCAN_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
