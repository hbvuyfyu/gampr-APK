# ========================================
# VIP App - Environment Variables for Railway
# ========================================
# Copy this file to .env and fill in the values
# Railway will automatically use these variables

# ========================================
# Database (PostgreSQL)
# ========================================
# Railway provides this automatically as DATABASE_URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/vip_db"

# ========================================
# JWT Settings
# ========================================
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"

# ========================================
# Server Settings
# ========================================
PORT=3000
NODE_ENV=production

# ========================================
# Cloudinary (for image uploads - payment proofs)
# ========================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ========================================
# Blockchain (for USDT BEP20 verification)
# ========================================
BSCSCAN_API_KEY=""
USDT_CONTRACT_ADDRESS="0x55d398326f99059fF775485246999027B3197955"
