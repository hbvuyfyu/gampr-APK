{
    "name": "game-event-backend",
    "version": "1.0.0",
    "description": "GAME EVENT Backend API",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate deploy",
        "prisma:push": "prisma db push",
        "prisma:seed": "ts-node prisma/seed.ts",
        "setup": "prisma generate && prisma migrate deploy && ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/client": "^5.7.0",
        "axios": "^1.6.2",
        "bcryptjs": "^2.4.3",
        "cloudinary": "^1.41.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "https-proxy-agent": "^7.0.2",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "multer-storage-cloudinary": "^4.0.0",
        "socks-proxy-agent": "^8.0.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.4",
        "prisma": "^5.7.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
